# ── apps/cms (Strapi) — copy to apps/cms/.env for local dev ─────────────────
HOST=0.0.0.0
PORT=1337
# Generate each one with: openssl rand -base64 32
APP_KEYS=key1,key2
API_TOKEN_SALT=changeme
ADMIN_JWT_SECRET=changeme
TRANSFER_TOKEN_SALT=changeme
JWT_SECRET=changeme
ENCRYPTION_KEY=changeme

# Local Postgres (docker compose up -d)
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=lasgalias
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false

# Providers (strategy pattern)
PROJECT_DATA_PROVIDER=manual   # manual | sinco
SINCO_BASE_URL=
SINCO_API_KEY=

# S3 uploads (empty locally => disk provider)
AWS_REGION=
UPLOADS_BUCKET=

# Email (empty SMTP_HOST => emails logged as JSON, not sent)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@lasgalias.com
EMAIL_REPLY_TO=no-reply@lasgalias.com

# Vercel Deploy Hook (rebuilds the site on publish; empty => no trigger)
VERCEL_DEPLOY_HOOK_URL=

# ── apps/web (Astro) — copy to apps/web/.env ────────────────────────────────
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=
PUBLIC_STRAPI_URL=http://localhost:1337
