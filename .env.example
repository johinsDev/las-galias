# ── apps/cms (Strapi) — copiar a apps/cms/.env para dev local ────────────────
HOST=0.0.0.0
PORT=1337
# Genera cada uno con: openssl rand -base64 32
APP_KEYS=key1,key2
API_TOKEN_SALT=changeme
ADMIN_JWT_SECRET=changeme
TRANSFER_TOKEN_SALT=changeme
JWT_SECRET=changeme
ENCRYPTION_KEY=changeme

# Postgres local (docker compose up -d)
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=lasgalias
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false

# Providers (strategy pattern)
PROJECT_DATA_PROVIDER=manual   # manual | sinco
SINCO_BASE_URL=
SINCO_API_KEY=

# Uploads S3 (vacío en local ⇒ provider local de disco)
AWS_REGION=
UPLOADS_BUCKET=

# Vercel Deploy Hook (rebuild del sitio al publicar contenido; vacío ⇒ no dispara)
VERCEL_DEPLOY_HOOK_URL=

# ── apps/web (Astro) — copiar a apps/web/.env ────────────────────────────────
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=
PUBLIC_STRAPI_URL=http://localhost:1337
