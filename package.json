{
  "name": "las-galias",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "sharp",
    "esbuild",
    "@swc/core",
    "lefthook",
    "aws-sdk",
    "core-js-pure"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{astro,ts,tsx,js,jsx,json,css,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{astro,ts,tsx,js,jsx,json,css,md,yml,yaml}\"",
    "knip": "knip-bun",
    "deploy:cms": "sst deploy",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.62.1",
    "astro-eslint-parser": "^2.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.1.1",
    "globals": "^17.7.0",
    "knip": "^6.24.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sst": "^3.17.0",
    "turbo": "^2.10.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
