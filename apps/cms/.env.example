# Server
HOST=0.0.0.0
PORT=1337

# Secrets — generate each with: openssl rand -base64 32
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
ENCRYPTION_KEY=tobemodified

# Database (docker compose up -d at the repo root)
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=lasgalias
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false

# Providers (strategy pattern)
PROJECT_DATA_PROVIDER=manual   # manual | sinco
SINCO_BASE_URL=
SINCO_API_KEY=

# S3 uploads (empty locally => disk provider)
AWS_REGION=
UPLOADS_BUCKET=

# Email (empty SMTP_HOST => emails logged as JSON, not sent)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@lasgalias.com
EMAIL_REPLY_TO=no-reply@lasgalias.com

# Vercel Deploy Hook (rebuilds the site on publish; empty => no trigger)
VERCEL_DEPLOY_HOOK_URL=

# Silence Vite 5 CJS deprecation notice printed by Strapi admin tooling
VITE_CJS_IGNORE_WARNING=1
