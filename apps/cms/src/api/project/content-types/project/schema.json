{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Real-estate projects. stage=expectation publishes with fewer required fields; stage=sale requires the full listing"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "stage": {
      "type": "enumeration",
      "enum": ["expectation", "sale"],
      "default": "expectation",
      "required": true
    },
    "syncFromSinco": {
      "type": "boolean",
      "default": false
    },
    "sincoId": {
      "type": "string"
    },
    "constructionStatus": {
      "type": "enumeration",
      "enum": ["launch", "presale", "construction", "immediate-delivery"]
    },
    "description": {
      "type": "blocks"
    },
    "priceFromCOP": {
      "type": "biginteger"
    },
    "city": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::city.city",
      "inversedBy": "projects",
      "required": true
    },
    "macroproject": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::macroproject.macroproject"
    },
    "amenities": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::amenity.amenity",
      "inversedBy": "projects"
    },
    "recommended": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::project.project"
    },
    "unitTypes": {
      "type": "component",
      "component": "project.unit-type",
      "repeatable": true
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "heroDesktop": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "heroMobile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "location": {
      "type": "component",
      "component": "shared.geo",
      "repeatable": false
    },
    "video": {
      "type": "string"
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
