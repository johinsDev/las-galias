{
  "kind": "collectionType",
  "collectionName": "ciudades",
  "info": {
    "singularName": "ciudad",
    "pluralName": "ciudades",
    "displayName": "Ciudad",
    "description": "Ciudades donde Las Galias tiene proyectos"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nombre",
      "required": true
    },
    "departamento": {
      "type": "string"
    },
    "imagen": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "proyectos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::proyecto.proyecto",
      "mappedBy": "ciudad"
    }
  }
}
