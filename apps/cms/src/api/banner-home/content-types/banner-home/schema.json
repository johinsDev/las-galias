{
  "kind": "collectionType",
  "collectionName": "banners_home",
  "info": {
    "singularName": "banner-home",
    "pluralName": "banners-home",
    "displayName": "Banner del home",
    "description": "Banners del home con imagen para desktop y mobile"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "titulo": {
      "type": "string"
    },
    "imagenDesktop": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "required": true
    },
    "imagenMobile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "required": true
    },
    "enlace": {
      "type": "string"
    },
    "orden": {
      "type": "integer",
      "default": 0
    },
    "activo": {
      "type": "boolean",
      "default": true
    }
  }
}
