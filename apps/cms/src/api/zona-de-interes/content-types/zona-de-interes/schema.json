{
  "kind": "collectionType",
  "collectionName": "zonas_de_interes",
  "info": {
    "singularName": "zona-de-interes",
    "pluralName": "zonas-de-interes",
    "displayName": "Zona de interés",
    "description": "Puntos de interés cercanos; SIEMPRE asociados a un macroproyecto para no mezclar ubicaciones"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true
    },
    "tipo": {
      "type": "enumeration",
      "enum": ["comercio", "salud", "educacion", "transporte", "recreacion"],
      "required": true
    },
    "distanciaTexto": {
      "type": "string"
    },
    "macroproyecto": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::macroproyecto.macroproyecto",
      "inversedBy": "zonasDeInteres",
      "required": true
    }
  }
}
