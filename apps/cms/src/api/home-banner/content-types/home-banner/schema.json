{
  "kind": "collectionType",
  "collectionName": "home_banners",
  "info": {
    "singularName": "home-banner",
    "pluralName": "home-banners",
    "displayName": "Home banner",
    "description": "Home banners with dedicated desktop and mobile images"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string"
    },
    "desktopImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "required": true
    },
    "mobileImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "required": true
    },
    "link": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  }
}
