{
  "kind": "collectionType",
  "collectionName": "macroproyectos",
  "info": {
    "singularName": "macroproyecto",
    "pluralName": "macroproyectos",
    "displayName": "Macroproyecto",
    "description": "Macroproyectos que agrupan proyectos y zonas de interés de una misma ubicación"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nombre",
      "required": true
    },
    "descripcion": {
      "type": "blocks"
    },
    "ciudad": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::ciudad.ciudad"
    },
    "galeria": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "ubicacion": {
      "type": "component",
      "component": "shared.geo",
      "repeatable": false
    },
    "zonasDeInteres": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::zona-de-interes.zona-de-interes",
      "mappedBy": "macroproyecto"
    }
  }
}
