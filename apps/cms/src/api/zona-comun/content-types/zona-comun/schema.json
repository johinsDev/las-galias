{
  "kind": "collectionType",
  "collectionName": "zonas_comunes",
  "info": {
    "singularName": "zona-comun",
    "pluralName": "zonas-comunes",
    "displayName": "Zona común",
    "description": "Amenidades reutilizables entre proyectos (piscina, gimnasio, etc.)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true
    },
    "icono": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "descripcion": {
      "type": "text"
    },
    "proyectos": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::proyecto.proyecto",
      "mappedBy": "zonasComunes"
    }
  }
}
