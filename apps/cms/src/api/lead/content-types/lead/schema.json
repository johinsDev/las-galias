{
  "kind": "collectionType",
  "collectionName": "leads",
  "info": {
    "singularName": "lead",
    "pluralName": "leads",
    "displayName": "Lead",
    "description": "Formularios guardados desde las PDP (especialmente proyectos en expectativa) para hacer push después"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "telefono": {
      "type": "string",
      "required": true
    },
    "mensaje": {
      "type": "text"
    },
    "proyecto": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::proyecto.proyecto"
    },
    "origen": {
      "type": "string"
    },
    "aceptaTratamientoDatos": {
      "type": "boolean",
      "required": true
    }
  }
}
