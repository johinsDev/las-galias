---
import { Image } from "astro:assets";

import Blocks from "@/components/Blocks.astro";
import Base from "@/layouts/Base.astro";
import { getPost, getPosts, mediaUrl } from "@/lib/strapi";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = await getPost(slug!);

if (!post) {
  return Astro.redirect("/blog");
}

const title = post.seo?.metaTitle ?? `${post.title} — Blog Las Galias`;
---

<Base
  title={title}
  description={post.seo?.metaDescription ?? post.excerpt ?? undefined}
  ogImage={mediaUrl(post.seo?.ogImage?.url ?? post.cover?.url)}
>
  <article class="container max-w-3xl py-12 md:py-16">
    <p class="text-label text-verde-700 font-semibold uppercase">Blog</p>
    <h1 class="text-h1 text-ink mt-2 font-extrabold">{post.title}</h1>
    {
      post.cover?.url && (
        <Image
          src={mediaUrl(post.cover.url)}
          alt={post.cover.alternativeText ?? post.title}
          width={1200}
          height={675}
          loading="eager"
          class="mt-8 rounded-xl"
        />
      )
    }
    <div class="mt-8">
      <Blocks content={post.content} />
    </div>
  </article>
</Base>
