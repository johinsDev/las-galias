---
import { Image } from "astro:assets";

import Blocks from "@/components/Blocks.astro";
import Base from "@/layouts/Base.astro";
import { getEntrada, getEntradas, mediaUrl } from "@/lib/strapi";

export async function getStaticPaths() {
  const entradas = await getEntradas();
  return entradas.map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const entrada = await getEntrada(slug!);

if (!entrada) {
  return Astro.redirect("/blog");
}

const title = entrada.seo?.metaTitle ?? `${entrada.titulo} — Blog Las Galias`;
---

<Base
  title={title}
  description={entrada.seo?.metaDescription ?? entrada.extracto ?? undefined}
  ogImage={mediaUrl(entrada.seo?.ogImage?.url ?? entrada.portada?.url)}
>
  <article class="container max-w-3xl py-12 md:py-16">
    <p class="text-label text-verde-700 font-semibold uppercase">Blog</p>
    <h1 class="text-h1 text-ink mt-2 font-extrabold">{entrada.titulo}</h1>
    {
      entrada.portada?.url && (
        <Image
          src={mediaUrl(entrada.portada.url)}
          alt={entrada.portada.alternativeText ?? entrada.titulo}
          width={1200}
          height={675}
          loading="eager"
          class="mt-8 rounded-xl"
        />
      )
    }
    <div class="mt-8">
      <Blocks content={entrada.contenido} />
    </div>
  </article>
</Base>
