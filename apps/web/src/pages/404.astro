---
import Base from "@/layouts/Base.astro";
---

<Base title="Página no encontrada — Las Galias">
  <section class="container py-24 text-center md:py-36">
    <p class="text-hero text-verde-100 font-extrabold">404</p>
    <h1 class="text-h2 text-ink mt-2 font-bold">Esta página no existe</h1>
    <p class="text-body text-ink-muted mt-3">
      Puede que el proyecto ya no esté disponible o que el enlace haya cambiado.
    </p>
    <a
      href="/proyectos"
      class="bg-primary text-primary-foreground shadow-cta hover:bg-primary-bright mt-8 inline-flex h-12 items-center rounded-lg px-6 font-semibold transition-colors"
    >
      Ver todos los proyectos
    </a>
  </section>
</Base>
