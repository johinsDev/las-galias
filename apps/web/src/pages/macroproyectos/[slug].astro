---
import { Image } from "astro:assets";

import Blocks from "@/components/Blocks.astro";
import Base from "@/layouts/Base.astro";
import { getMacroprojects, mediaUrl } from "@/lib/strapi";

export async function getStaticPaths() {
  const macroprojects = await getMacroprojects();
  return macroprojects.map((m) => ({ params: { slug: m.slug }, props: { macro: m } }));
}

const { macro } = Astro.props;
const categories: Record<string, string> = {
  commerce: "Comercio",
  health: "Salud",
  education: "Educación",
  transport: "Transporte",
  recreation: "Recreación",
};
---

<Base title={`${macro.name} — Macroproyectos Las Galias`}>
  <section class="container py-12 md:py-16">
    <p class="text-label text-verde-700 font-semibold uppercase">
      Macroproyecto · {macro.city?.name}
    </p>
    <h1 class="text-h1 text-ink mt-1 font-extrabold">{macro.name}</h1>

    {
      macro.gallery?.[0]?.url && (
        <Image
          src={mediaUrl(macro.gallery[0].url)}
          alt={macro.name}
          width={1400}
          height={700}
          loading="eager"
          class="mt-8 max-h-[55vh] w-full rounded-xl object-cover"
        />
      )
    }

    {
      macro.description != null && (
        <div class="mt-10 max-w-3xl" data-reveal>
          <Blocks content={macro.description} />
        </div>
      )
    }

    {
      (macro.pointsOfInterest?.length ?? 0) > 0 && (
        <div class="mt-12">
          <h2 class="text-h2 text-ink font-bold" data-reveal>
            Zonas de interés
          </h2>
          <ul class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {macro.pointsOfInterest!.map((poi) => (
              <li class="border-line rounded-lg border p-4" data-reveal>
                <p class="text-caption text-verde-700 font-semibold uppercase">
                  {categories[poi.category] ?? poi.category}
                </p>
                <p class="text-body text-ink mt-1 font-medium">{poi.name}</p>
                {poi.distanceText && (
                  <p class="text-caption text-ink-muted mt-1">{poi.distanceText}</p>
                )}
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </section>
</Base>
