---
import { Image } from "astro:assets";

import Base from "@/layouts/Base.astro";
import { getMacroproyectos, mediaUrl } from "@/lib/strapi";

const macroproyectos = await getMacroproyectos();
---

<Base title="Macroproyectos — Las Galias" description="Los macroproyectos urbanos de Las Galias.">
  <section class="container py-12 md:py-16">
    <p class="text-label text-verde-700 font-semibold uppercase">Macroproyectos</p>
    <h1 class="text-h1 text-ink mt-1 font-bold">Ciudades dentro de la ciudad</h1>

    {
      macroproyectos.length > 0 ? (
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          {macroproyectos.map((macro) => (
            <a
              href={`/macroproyectos/${macro.slug}`}
              class="shadow-card group relative block overflow-hidden rounded-xl"
              data-reveal
            >
              {macro.galeria?.[0]?.url && (
                <Image
                  src={mediaUrl(macro.galeria[0].url)}
                  alt={macro.nombre}
                  width={800}
                  height={500}
                  class="aspect-[8/5] w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent" />
              <div class="absolute bottom-0 p-6">
                <p class="text-caption text-white/70 uppercase">{macro.ciudad?.nombre}</p>
                <h2 class="text-h3 font-bold text-white">{macro.nombre}</h2>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-body text-ink-muted mt-8">Aún no hay macroproyectos publicados.</p>
      )
    }
  </section>
</Base>
