---
import ProjectCard from "@/components/ProjectCard.astro";
import Base from "@/layouts/Base.astro";
import { getProjects } from "@/lib/strapi";

const projects = await getProjects();
const cities = [
  ...new Map(projects.filter((p) => p.city).map((p) => [p.city.slug, p.city])).values(),
];
---

<Base title="Proyectos — Las Galias" description="Todos los proyectos de vivienda de Las Galias.">
  <section class="container py-12 md:py-16">
    <p class="text-label text-verde-700 font-semibold uppercase">Proyectos</p>
    <h1 class="text-h1 text-ink mt-1 font-bold">Nuestros proyectos</h1>

    {
      cities.length > 1 && (
        <div class="mt-6 flex flex-wrap gap-2" id="city-filter">
          <button
            type="button"
            data-filter=""
            class="bg-verde-700 text-caption rounded-full px-4 py-1.5 font-semibold text-white"
          >
            Todas
          </button>
          {cities.map((city) => (
            <button
              type="button"
              data-filter={city.slug}
              class="bg-surface text-ink-muted text-caption hover:text-ink rounded-full px-4 py-1.5 font-semibold"
            >
              {city.name}
            </button>
          ))}
        </div>
      )
    }

    {
      projects.length > 0 ? (
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="projects-grid">
          {projects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      ) : (
        <p class="text-body text-ink-muted mt-8">
          Muy pronto publicaremos nuestros proyectos. Vuelve pronto.
        </p>
      )
    }
  </section>

  <script>
    // City filter, plain DOM (zero framework): hides cards by data-city.
    function initCityFilter() {
      const container = document.getElementById("city-filter");
      if (!container) return;
      container.addEventListener("click", (event) => {
        const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-filter]");
        if (!button) return;
        const filter = button.dataset.filter ?? "";
        container.querySelectorAll<HTMLButtonElement>("[data-filter]").forEach((b) => {
          const active = b === button;
          b.classList.toggle("bg-verde-700", active);
          b.classList.toggle("text-white", active);
          b.classList.toggle("bg-surface", !active);
          b.classList.toggle("text-ink-muted", !active);
        });
        document.querySelectorAll<HTMLElement>("#projects-grid [data-city]").forEach((card) => {
          card.style.display = !filter || card.dataset.city === filter ? "" : "none";
        });
      });
    }
    initCityFilter();
    document.addEventListener("astro:page-load", initCityFilter);
  </script>
</Base>
