---
import { Image } from "astro:assets";

import Blocks from "@/components/Blocks.astro";
import Price from "@/components/Price.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import CurrencySwitcher from "@/islands/CurrencySwitcher";
import LeadForm from "@/islands/LeadForm";
import MortgageCalculator from "@/islands/MortgageCalculator";
import Base from "@/layouts/Base.astro";
import {
  getCalculatorConfig,
  getExchangeRate,
  getProject,
  getProjects,
  mediaUrl,
} from "@/lib/strapi";

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const [project, rates, calculator] = await Promise.all([
  getProject(slug!),
  getExchangeRate(),
  getCalculatorConfig(),
]);

if (!project) {
  return Astro.redirect("/proyectos");
}

const isExpectation = project.stage === "expectation";
const hero = project.heroDesktop ?? project.heroMobile;
const pointsOfInterest = project.macroproject?.pointsOfInterest ?? [];
const recommended = project.recommended ?? [];
const title = project.seo?.metaTitle ?? `${project.name} — Las Galias`;
const description = project.seo?.metaDescription ?? undefined;
---

<Base title={title} description={description} ogImage={mediaUrl(project.seo?.ogImage?.url)}>
  <section class="relative">
    {
      hero?.url && (
        <picture>
          {project.heroDesktop?.url && (
            <source media="(min-width: 768px)" srcset={mediaUrl(project.heroDesktop.url)} />
          )}
          <Image
            src={mediaUrl(hero.url)}
            alt={hero.alternativeText ?? project.name}
            width={1600}
            height={700}
            loading="eager"
            class="max-h-[60vh] w-full object-cover"
          />
        </picture>
      )
    }
    <div class="container py-10">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-label text-verde-700 font-semibold uppercase">
            {project.city?.name}
            {
              isExpectation && (
                <span class="bg-arena text-ink ml-2 rounded-full px-3 py-0.5">Muy pronto</span>
              )
            }
          </p>
          <h1 class="text-h1 text-ink mt-1 font-extrabold">{project.name}</h1>
          {
            !isExpectation && project.priceFromCOP && (
              <p class="text-h3 text-verde-700 mt-2 font-bold">
                <Price copValue={project.priceFromCOP} prefix="Desde" />
              </p>
            )
          }
        </div>
        {
          !isExpectation && rates?.copPerUsd && rates?.copPerEur && (
            <CurrencySwitcher
              client:visible
              copPerUsd={rates.copPerUsd}
              copPerEur={rates.copPerEur}
            />
          )
        }
      </div>
    </div>
  </section>

  {
    isExpectation ? (
      <section class="container grid gap-12 pb-16 md:grid-cols-2">
        <div data-reveal>
          <h2 class="text-h2 text-ink font-bold">Un nuevo proyecto está por llegar</h2>
          <p class="text-body-lg text-ink-muted mt-4">
            Déjanos tus datos y sé de los primeros en conocer los precios de lanzamiento, las
            tipologías y los beneficios de preventa.
          </p>
          {project.description != null && (
            <div class="mt-6">
              <Blocks content={project.description} />
            </div>
          )}
        </div>
        <div class="shadow-card rounded-xl bg-white p-6" data-reveal>
          <h3 class="text-h4 text-ink mb-4 font-bold">Quiero información de lanzamiento</h3>
          <LeadForm
            client:visible
            projectDocumentId={project.documentId}
            source={`pdp-expectation:${project.slug}`}
          />
        </div>
      </section>
    ) : (
      <>
        {project.description != null && (
          <section class="container max-w-3xl pb-12" data-reveal>
            <Blocks content={project.description} />
          </section>
        )}

        {(project.unitTypes?.length ?? 0) > 0 && (
          <section class="bg-section py-16">
            <div class="container">
              <h2 class="text-h2 text-ink font-bold" data-reveal>
                Tipologías
              </h2>
              <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {project.unitTypes!.map((unit) => (
                  <div class="shadow-card rounded-xl bg-white p-5" data-reveal>
                    {unit.floorPlan?.url && (
                      <Image
                        src={mediaUrl(unit.floorPlan.url)}
                        alt={`Plano ${unit.name}`}
                        width={480}
                        height={360}
                        class="bg-surface mb-4 aspect-[4/3] w-full rounded-lg object-contain"
                      />
                    )}
                    <h3 class="text-h4 text-ink font-bold">{unit.name}</h3>
                    <p class="text-body-sm text-ink-muted mt-1">
                      {unit.areaM2} m² · {unit.bedrooms} hab · {unit.bathrooms} baños
                    </p>
                    {unit.priceCOP && (
                      <p class="text-body text-verde-700 mt-2 font-semibold">
                        <Price copValue={unit.priceCOP} />
                      </p>
                    )}
                  </div>
                ))}
              </div>
            </div>
          </section>
        )}

        {(project.amenities?.length ?? 0) > 0 && (
          <section class="container py-16">
            <h2 class="text-h2 text-ink font-bold" data-reveal>
              Zonas comunes
            </h2>
            <ul class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
              {project.amenities!.map((amenity) => (
                <li class="bg-surface flex items-center gap-3 rounded-lg p-4" data-reveal>
                  {amenity.icon?.url && (
                    <img src={mediaUrl(amenity.icon.url)} alt="" width="28" height="28" />
                  )}
                  <span class="text-body-sm text-ink font-medium">{amenity.name}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        {pointsOfInterest.length > 0 && (
          <section class="container pb-16">
            <h2 class="text-h2 text-ink font-bold" data-reveal>
              Cerca de ti
            </h2>
            <p class="text-body-sm text-ink-muted mt-1">
              Zonas de interés del macroproyecto {project.macroproject?.name}.
            </p>
            <ul class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {pointsOfInterest.map((poi) => (
                <li class="border-line flex items-center justify-between rounded-lg border p-4">
                  <span class="text-body-sm text-ink font-medium">{poi.name}</span>
                  <span class="text-caption text-ink-muted">{poi.distanceText}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        {project.priceFromCOP && calculator?.annualInterestRate && (
          <section class="bg-section py-16">
            <div class="container grid items-start gap-10 md:grid-cols-2">
              <div data-reveal>
                <h2 class="text-h2 text-ink font-bold">¿Cuánto pagarías al mes?</h2>
                <p class="text-body text-ink-muted mt-3 max-w-md">
                  Simula tu crédito hipotecario con la tasa de referencia vigente y descubre qué tan
                  cerca estás de tu nuevo hogar.
                </p>
              </div>
              <MortgageCalculator
                client:visible
                priceFromCOP={Number(project.priceFromCOP)}
                annualInterestRate={calculator.annualInterestRate}
                maxTermYears={calculator.maxTermYears}
                maxFinancingPercent={calculator.maxFinancingPercent}
              />
            </div>
          </section>
        )}

        {recommended.length > 0 && (
          <section class="container py-16">
            <h2 class="text-h2 text-ink font-bold" data-reveal>
              También te puede interesar
            </h2>
            <p class="text-body-sm text-ink-muted mt-1">Otros proyectos en {project.city?.name}.</p>
            <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {recommended.map((rec) => (
                <ProjectCard project={rec} />
              ))}
            </div>
          </section>
        )}
      </>
    )
  }
</Base>
