---
import { Image } from "astro:assets";
import type { Proyecto } from "@lasgalias/schemas";

import Precio from "@/components/Precio.astro";
import { mediaUrl } from "@/lib/strapi";

interface Props {
  proyecto: Proyecto;
}

const { proyecto } = Astro.props;
const hero = proyecto.heroDesktop ?? proyecto.heroMobile;
const esExpectativa = proyecto.etapa === "expectativa";
---

<article
  class="shadow-card group hover:shadow-card-lg overflow-hidden rounded-xl bg-white transition-shadow"
  data-ciudad={proyecto.ciudad?.slug}
  data-reveal
>
  <a href={`/proyectos/${proyecto.slug}`} class="block">
    <div class="bg-surface relative aspect-[4/3] overflow-hidden">
      {
        hero?.url && (
          <Image
            src={mediaUrl(hero.url)}
            alt={hero.alternativeText ?? proyecto.nombre}
            width={640}
            height={480}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        )
      }
      {
        esExpectativa && (
          <span class="bg-arena text-ink text-caption absolute top-3 left-3 rounded-full px-3 py-1 font-semibold uppercase">
            Muy pronto
          </span>
        )
      }
    </div>
    <div class="p-5">
      <p class="text-caption text-ink-muted uppercase">{proyecto.ciudad?.nombre}</p>
      <h3 class="text-h4 text-ink mt-1 font-bold">{proyecto.nombre}</h3>
      {
        !esExpectativa && proyecto.precioDesdeCOP && (
          <p class="text-body text-verde-700 mt-2 font-semibold">
            <Precio valorCOP={proyecto.precioDesdeCOP} prefix="Desde" />
          </p>
        )
      }
    </div>
  </a>
</article>
