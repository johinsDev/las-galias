---
const year = new Date().getFullYear();
---

<footer class="bg-verde-950 mt-24 py-12 text-white">
  <div
    class="container flex flex-col items-start justify-between gap-8 md:flex-row md:items-center"
  >
    <div>
      <p class="text-h4 font-extrabold">Las Galias</p>
      <p class="text-body-sm mt-1 text-white/60">Construimos los lugares donde vive Colombia.</p>
    </div>
    <nav aria-label="footer">
      <ul class="text-body-sm flex gap-6 text-white/80">
        <li><a href="/proyectos" class="hover:text-white">Proyectos</a></li>
        <li><a href="/blog" class="hover:text-white">Blog</a></li>
        <li><a href="/contacto" class="hover:text-white">Contacto</a></li>
      </ul>
    </nav>
  </div>
  <div class="container mt-8 border-t border-white/10 pt-6">
    <p class="text-caption text-white/50">
      © {year} Constructora Las Galias. Todos los derechos reservados.
    </p>
  </div>
</footer>
