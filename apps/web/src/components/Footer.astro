---
const year = new Date().getFullYear();

const columns = [
  {
    title: "Proyectos",
    links: [
      { label: "Todos los proyectos", href: "/proyectos" },
      { label: "Macroproyectos", href: "/macroproyectos" },
      { label: "Sobre planos", href: "/proyectos" },
    ],
  },
  {
    title: "Empresa",
    links: [
      { label: "Nosotros", href: "/" },
      { label: "Blog", href: "/blog" },
      { label: "Trabaja con nosotros", href: "/contacto" },
    ],
  },
  {
    title: "Contacto",
    links: [
      { label: "Servicio al cliente", href: "/contacto" },
      { label: "Agenda tu cita", href: "/contacto" },
      { label: "Compra desde el exterior", href: "/contacto" },
    ],
  },
];
---

<footer class="bg-ink-900 text-white">
  <div class="container grid gap-10 py-14 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
    <div>
      <div class="flex items-center gap-2">
        <span class="inline-block size-6 rounded-md bg-white"></span>
        <span class="text-[1.05rem] font-extrabold tracking-tight">LAS GALIAS</span>
      </div>
      <p class="text-body-sm mt-3 max-w-xs text-white/55">
        Construimos los lugares donde vive Colombia. +30 mil viviendas entregadas.
      </p>
      <div class="mt-5 flex gap-2">
        {
          ["in", "ig", "fb", "yt"].map((s) => (
            <span
              class="flex size-9 items-center justify-center rounded-lg bg-white/10 text-xs font-semibold text-white/70"
              aria-hidden="true"
            >
              {s}
            </span>
          ))
        }
      </div>
    </div>
    {
      columns.map((col) => (
        <nav aria-label={col.title}>
          <p class="eyebrow text-white/40">{col.title}</p>
          <ul class="mt-4 space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-body-sm text-white/70 transition-colors hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }
  </div>
  <div class="border-t border-white/10">
    <div class="container flex flex-col gap-2 py-6 md:flex-row md:items-center md:justify-between">
      <p class="text-caption text-white/45">
        © {year} Constructora Las Galias. Todos los derechos reservados.
      </p>
      <p class="text-caption text-white/45">
        Vigilado Superintendencia de Sociedades · NIT 900.000.000-0
      </p>
    </div>
  </div>
</footer>
