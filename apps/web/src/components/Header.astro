---
const links = [
  { href: "/proyectos", label: "Proyectos" },
  { href: "/macroproyectos", label: "Macroproyectos" },
  { href: "/blog", label: "Blog" },
  { href: "/contacto", label: "Contacto" },
];
const current = Astro.url.pathname;
---

<header class="shadow-nav sticky top-0 z-40 bg-white/90 backdrop-blur">
  <div class="container flex h-16 items-center justify-between">
    <a href="/" class="text-h4 text-verde-900 font-extrabold tracking-tight"> Las Galias </a>
    <nav aria-label="principal">
      <ul class="flex items-center gap-6">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "text-body-sm hover:text-verde-700 font-medium transition-colors",
                  current.startsWith(link.href) ? "text-verde-700" : "text-ink-muted",
                ]}
                aria-current={current.startsWith(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
