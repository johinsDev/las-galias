---
const links = [
  { href: "/proyectos", label: "Proyectos" },
  { href: "/macroproyectos", label: "Macroproyectos" },
  { href: "/blog", label: "Blog" },
  { href: "/contacto", label: "Servicio al cliente" },
];
const current = Astro.url.pathname;
---

<header class="border-line/80 sticky top-0 z-50 border-b bg-white/85 backdrop-blur-md">
  <div class="container flex h-16 items-center justify-between gap-6">
    <a href="/" class="flex items-center gap-2">
      <span class="bg-ink inline-block size-6 rounded-md"></span>
      <span class="text-ink text-[1.05rem] font-extrabold tracking-tight">LAS GALIAS</span>
    </a>

    <nav aria-label="principal" class="hidden md:block">
      <ul class="flex items-center gap-7">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "text-body-sm font-medium transition-colors",
                  current.startsWith(link.href) ? "text-ink" : "text-ink-muted hover:text-ink",
                ]}
                aria-current={current.startsWith(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="/contacto"
        class="border-line-strong text-ink hover:bg-surface hidden h-9 items-center rounded-lg border px-3.5 text-sm font-medium transition-colors sm:inline-flex"
      >
        Ingresa como cliente
      </a>
      <a
        href="/contacto"
        class="bg-primary text-primary-foreground shadow-cta hover:bg-primary-bright inline-flex h-9 items-center rounded-lg px-4 text-sm font-semibold transition-colors"
      >
        Agenda tu cita
      </a>
    </div>
  </div>
</header>
